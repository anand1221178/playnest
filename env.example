# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin ─────────────────────────────────────────────
ADMIN_PASSWORD=change-this-to-a-strong-password
ADMIN_JWT_SECRET=change-this-to-a-random-32-char-string

# ── PayFast ───────────────────────────────────────────
NEXT_PUBLIC_PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
NEXT_PUBLIC_PAYFAST_MODE=sandbox

# ── Resend (email) ────────────────────────────────────
RESEND_API_KEY=re_your-api-key
ORDER_NOTIFICATION_EMAIL=bhavesh@example.com
DELIVERY_COMPANY_EMAIL=courier@example.com

# ── Site ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.co.za
